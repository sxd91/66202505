---
import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import MainGridLayout from "../../../layouts/MainGridLayout.astro";
// import type { GetStaticPaths } from "astro";
import type { AlbumGroup, Photo } from "../../../types/album";
import { scanAlbums } from "../../../utils/album-scanner";

// 检查相册页面是否启用
if (!siteConfig.featurePages.albums) {
	return Astro.redirect("/404/");
}

export const getStaticPaths = async () => {
	const albumsData = await scanAlbums();
	return albumsData.map((album) => ({
		params: { id: album.id },
		props: { album },
	}));
};

interface Props {
	album: AlbumGroup;
}

const { album } = Astro.props;

if (!album) {
	return Astro.redirect("/404/");
}
---

<MainGridLayout title={album.title} description={album.description || album.title}>
  <div class="w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      
      <!-- 返回按钮 -->
      <div class="mb-6">
        <a 
          href="/albums/" 
          class="inline-flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-[var(--primary)] transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          {i18n(I18nKey.albumsBackToList)}
        </a>
      </div>

      <!-- 相册标题信息 -->
      <header class="mb-8">
        <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">
          {album.title}
        </h1>
        
        {album.description && (
          <p class="text-neutral-600 dark:text-neutral-400 mb-4">
            {album.description}
          </p>
        )}
        
        <!-- 相册元数据 -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 dark:text-neutral-500">
          <span>{album.photos.length} {album.photos.length > 1 ? i18n(I18nKey.albumsPhotosCount) : i18n(I18nKey.albumsPhotoCount)}</span>
          <time>{new Date(album.date).toLocaleDateString('zh-CN')}</time>
          {album.location && (
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
              </svg>
              {album.location}
            </span>
          )}
        </div>
        
        <!-- 标签 -->
        {album.tags && album.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {album.tags.map((tag: string) => (
              <span class="btn-regular h-8 text-sm px-3 rounded-lg">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- 照片网格 -->
      <div 
        class="photo-gallery"
        style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; width: 100%;"
      >
        {album.photos.map((photo: Photo, index: number) => {
          const thumbnail = photo.thumbnail || `/images/albums/${album.id}/${photo.src.split('/').pop()?.replace(/\.[^.]+$/, '_thumb.jpg') || ''}`;
          return (
            <figure 
              class="photo-item group relative overflow-hidden rounded-lg"
              data-index={index}
            >
              <a 
                href="javascript:void(0)"
                data-src={photo.src}
                data-fancybox={`gallery-${album.id}`}
                class="block photo-link"
                data-caption={photo.title || photo.alt}
              >
                <div class="photo-placeholder bg-neutral-100 dark:bg-neutral-800 relative overflow-hidden">
                  <img 
                    src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'%3E%3Crect fill='%23f3f4f6' width='1' height='1'/%3E%3C/svg%3E"
                    data-src={photo.thumbnail || photo.src}
                    data-full-src={photo.src}
                    alt={photo.alt}
                    class="photo-image w-full h-full object-cover lazy-image"
                    loading="lazy"
                  />
                  <div class="loading-overlay absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                    </svg>
                  </div>
                </div>
              </a>
            </figure>
          );
        })}
      </div>
    </div>
  </div>

</MainGridLayout>

<script>
  class PhotoGalleryOptimizer {
    private imagesLoaded: number = 0;
    private totalImages: number = 0;
    private observer: IntersectionObserver | null = null;

    constructor() {
      this.init();
    }

    init() {
      this.totalImages = document.querySelectorAll('.lazy-image').length;
      this.setupLazyLoading();
      this.optimizeLayout();
    }

    setupLazyLoading() {
      this.observer = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            this.loadImage(img);
            observer.unobserve(img);
          }
        });
      }, {
        rootMargin: '150px',
        threshold: 0.1
      });

      if (this.observer) {
        document.querySelectorAll('.lazy-image').forEach(img => {
          this.observer!.observe(img);
        });
      }
    }

    loadImage(img) {
      const src = img.getAttribute('data-src');
      const fullSrc = img.getAttribute('data-full-src');
      
      const tempImg = new Image();
      tempImg.onload = () => {
        img.src = src;
        img.classList.add('image-loaded');
        
        if (fullSrc && fullSrc !== src) {
          const fullImg = new Image();
          fullImg.onload = () => {
            img.src = fullSrc;
          };
          fullImg.src = fullSrc;
        }
        
        this.imagesLoaded++;
      };
      tempImg.onerror = () => {
        img.src = fullSrc || src;
        img.classList.add('image-loaded');
        this.imagesLoaded++;
      };
      tempImg.src = src;
    }

    optimizeLayout() {
      const gallery = document.querySelector('.photo-gallery');
      if (gallery) {
        gallery.classList.add('layout-stable');
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      new PhotoGalleryOptimizer();
    });
  } else {
    new PhotoGalleryOptimizer();
  }
</script>

<style>
  .photo-gallery {
    display: grid !important;
    gap: 1rem;
    grid-template-columns: repeat(3, 1fr) !important;
    width: 100% !important;
    max-width: 100% !important;
  }

  .photo-gallery.grid-layout {
    display: grid !important;
    grid-template-columns: repeat(3, 1fr) !important;
  }

  .photo-gallery.grid-layout[data-columns="2"] {
    grid-template-columns: repeat(2, 1fr) !important;
  }

  .photo-gallery.grid-layout[data-columns="3"] {
    grid-template-columns: repeat(3, 1fr) !important;
  }

  .photo-gallery.grid-layout[data-columns="4"] {
    grid-template-columns: repeat(4, 1fr) !important;
  }

  .photo-gallery.masonry-layout {
    display: block !important;
    columns: 3;
    column-gap: 1rem;
    column-fill: auto;
  }

  @media (min-width: 768px) {
    .photo-gallery {
      grid-template-columns: repeat(3, 1fr) !important;
    }
    
    .photo-gallery.grid-layout[data-columns="2"] {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    
    .photo-gallery.grid-layout[data-columns="3"] {
      grid-template-columns: repeat(3, 1fr) !important;
    }
    
    .photo-gallery.grid-layout[data-columns="4"] {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    
    .photo-gallery.masonry-layout {
      columns: 3;
    }
  }

  @media (min-width: 1024px) {
    .photo-gallery {
      grid-template-columns: repeat(3, 1fr) !important;
    }
    
    .photo-gallery.grid-layout[data-columns="4"] {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    
    .photo-gallery.masonry-layout[data-columns="4"] {
      columns: 4;
    }
  }

  @media (max-width: 767px) {
    .photo-gallery {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 0.5rem !important;
    }
    
    .photo-gallery.grid-layout {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    
    .photo-gallery.masonry-layout {
      columns: 2;
      column-gap: 0.5rem;
    }
  }

  .photo-gallery .photo-item {
    break-inside: avoid;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeIn 0.3s ease forwards;
  }

  @media (max-width: 767px) {
    .photo-gallery .photo-item {
      margin-bottom: 0.5rem;
    }
  }

  .photo-gallery.grid-layout .photo-item {
    aspect-ratio: 1;
  }

  .photo-item:nth-child(4n+1) { animation-delay: 0ms; }
  .photo-item:nth-child(4n+2) { animation-delay: 50ms; }
  .photo-item:nth-child(4n+3) { animation-delay: 100ms; }
  .photo-item:nth-child(4n+4) { animation-delay: 150ms; }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .photo-placeholder {
    aspect-ratio: 1;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  }

  .photo-image {
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .photo-image.image-loaded {
    opacity: 1;
  }

  .photo-image:not(.image-loaded) {
    opacity: 0.7;
    filter: blur(3px);
  }

  .photo-link:hover .photo-image {
    transform: scale(1.05);
  }

  .layout-stable {
    contain: layout style paint;
  }
</style>